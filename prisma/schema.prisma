generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum UserRole {
  SUPERADMIN
  ADMIN
  CLIENT
  PERFORMER
}

enum OrderStatus {
  CREATED
  PENDING
  PAID
  IN_PROGRESS
  SHIPPED
  DONE
  CANCELED
}

enum ProductType {
  SIMPLE
  CONFIGURATOR
  REQUEST_QUOTE
}

//
// USERS
//

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String

  createdAt DateTime @default(now())

  sessions Session[]
  orders   Order[]
  quotes   QuoteRequest[]
  logs     ActivityLog[]
}

model Session {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())
}

//
// CATALOG
//

model Category {
  id String @id @default(cuid())

  name String
  slug String @unique

  products Product[]

  createdAt DateTime @default(now())
}

model Product {
  id String @id @default(cuid())

  title String
  slug  String @unique

  description String?

  type ProductType @default(SIMPLE)

  price Int?

  isActive Boolean @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images ProductImage[]

  attributes Json? // гибкие параметры (котлы, конфигураторы)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems    OrderItem[]
  quoteRequests QuoteRequest[]
}

model ProductImage {
  id String @id @default(cuid())

  url       String
  productId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

//
// ORDERS (B2B/B2C)
//

model Order {
  id String @id @default(cuid())

  userId String
  user   User @relation(fields: [userId], references: [id])

  status OrderStatus @default(CREATED)

  total Int @default(0)

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int @default(1)
  price    Int
}

model Visit {
  id        String   @id @default(cuid())
  path      String
  ip        String?
  userAgent String?
  referrer  String?

  createdAt DateTime @default(now())
}
model Event {
  id        String   @id @default(cuid())

  type      String   // "CLICK" | "QUOTE" | "ORDER" | "VIEW"
  path      String?

  productId String?
  userId    String?

  metadata  Json?

  createdAt DateTime @default(now())
}
//
// QUOTES / КП (очень важно для котлов и B2B)
//

model QuoteRequest {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  message String?

  status String @default("NEW")

  payload Json? // конфигуратор котла

  createdAt DateTime @default(now())
}

//
// LOGS / ANALYTICS
//

model ActivityLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action String
  meta   Json?

  createdAt DateTime @default(now())
}

//
// ADDITIONAL (future-proof)
//

model File {
  id String @id @default(cuid())

  url  String
  type String

  createdAt DateTime @default(now())
}
